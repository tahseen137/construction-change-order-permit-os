APP_ENV=development
DATABASE_URL=
DATABASE_PATH=data/construction_ops.db
UPLOADS_DIR=data/uploads
BOOTSTRAP_WORKSPACE_NAME=Demo GC Workspace
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-for-first-login
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SESSION_SECRET=replace-with-a-long-random-secret
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
TRUSTED_HOSTS=localhost,127.0.0.1
ENFORCE_HTTPS=false
AUTO_CREATE_SCHEMA=true
RUN_DB_MIGRATIONS=false
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=false
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=no-reply@example.com
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
APPROVAL_THRESHOLD_PM_USD=25000
APPROVAL_THRESHOLD_FINANCE_USD=100000
